    {
      "parameters": {
        "jsCode": "const telegramId = $input.item.json.telegram_id;\nconst mensaje = $input.item.json.mensaje_final.toLowerCase().trim();\n\n// Palabras que indican respuesta corta/ambigua\nconst esAmbiguo = /^(si|sí|no|confirmo|correcto|es correcto|si confirmo|dale|ok|okay|va|sale|perfecto|listo|claro|si todo|todo bien|va bien|asi es|eso es)$/i.test(mensaje);\n\n// Palabras clave de cada agente\nconst keywordsConstruye = ['cuadrilla', 'construcción', 'construccion', 'asignar', 'faltantes', 'vivienda', 'regreso de herramienta', 'regresar herramienta'];\nconst keywordsBodega = ['bodega', 'inventario', 'pedir material', 'regresar material', 'ubicacion', 'ubicación'];\n\n// Static data para recordar último agente por usuario\nconst staticData = $getWorkflowStaticData('global');\n\nlet ruta = null;\n\nif (!esAmbiguo) {\n  // Mensaje claro — detectar por keywords\n  const esConstruye = keywordsConstruye.some(k => mensaje.includes(k));\n  const esBodega = keywordsBodega.some(k => mensaje.includes(k));\n  \n  if (esConstruye) ruta = 'construye';\n  else if (esBodega) ruta = 'bodega';\n  \n  // Guardar la ruta si la detectamos\n  if (ruta) {\n    staticData[`ruta_${telegramId}`] = ruta;\n  }\n} else {\n  // Mensaje ambiguo — usar última ruta guardada\n  ruta = staticData[`ruta_${telegramId}`] || null;\n}\n\nreturn [{\n  json: {\n    ...($input.item.json),\n    ruta_detectada: ruta\n  }\n}];"
      },
