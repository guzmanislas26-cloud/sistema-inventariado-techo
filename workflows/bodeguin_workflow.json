    {
      "parameters": {
        "jsCode": "const text = $input.item.json.output || '';\n\nconst enviarManual = text.includes('[ENVIAR_MANUAL]');\n\nconst clean = text\n  .replace(/\\[ENVIAR_MANUAL\\]/g, '')\n  .replace(/\\*\\*(.*?)\\*\\*/g, '$1')\n  .replace(/\\*(.*?)\\*/g, '$1')\n  .replace(/__(.*?)__/g, '$1')\n  .replace(/`(.*?)`/g, '$1')\n  .replace(/#{1,6}\\s/g, '')\n  .replace(/\\[(.*?)\\]\\(.*?\\)/g, '$1')\n  .replace(/^\\s*\\*\\s/gm, '- ')\n  .replace(/└/g, '-')\n  .replace(/[^\\x00-\\x7F\\u00C0-\\u024F\\u0400-\\u04FF\\u2600-\\u27BF\\uD83C-\\uDBFF\\uDC00-\\uDFFF]/g, '')\n  .trim();\n\nreturn [{ json: { output: clean, enviar_manual: enviarManual } }];"
      },
